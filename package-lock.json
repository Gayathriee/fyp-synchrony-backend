import os
from dotenv import load_dotenv
from google import genai
from fastapi import FastAPI, HTTPException, BackgroundTasks, WebSocket
from fastapi.middleware.cors import CORSMiddleware
from pydantic import BaseModel
from collections import deque
import numpy as np
import neurokit2 as nk
import asyncio
from datetime import datetime
import uvicorn
import math

# Load the hidden environment variables (.env)
load_dotenv()

# Initialize the modern Gemini Client securely!
llm_client = genai.Client(api_key=os.getenv("GEMINI_API_KEY"))

app = FastAPI(title="Hybrid AI Synchrony Backend")

# Allow the React frontend to talk to the FastAPI backend
app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

WINDOW_SIZE = 3000 

participant_buffers = {1: deque(maxlen=WINDOW_SIZE), 2: deque(maxlen=WINDOW_SIZE), 3: deque(maxlen=WINDOW_SIZE)}
last_inference_time = {1: 0, 2: 0, 3: 0}
rmssd_history = {1: [], 2: [], 3: []}
current_stress_states = {1: "Calm", 2: "Calm", 3: "Calm"}
last_intervention_time = 0

class SensorData(BaseModel):
    participant_id: int
    ppg_samples: list[float]

# === WEBSOCKET SETUP ===
active_websockets = []

@app.websocket("/ws")
async def websocket_endpoint(websocket: WebSocket):
    await websocket.accept()
    active_websockets.append(websocket)
    try:
        while True:
            await websocket.receive_text()
    except Exception:
        active_websockets.remove(websocket)

async def broadcast_to_dashboard(message_dict):
    """Pushes real-time JSON data to the React dashboard"""
    for connection in active_websockets:
        try:
            await connection.send_json(message_dict)
        except Exception:
            pass

# === CLINICAL MATH ===
def classify_stress_clinically(rmssd, sdnn, hr, pnn50):
    scores = {"Calm": 0, "Mild Stress": 0, "High Stress": 0}

    if rmssd > 50: scores["Calm"] += 1
    elif 20 <= rmssd <= 50: scores["Mild Stress"] += 1
    elif rmssd < 20: scores["High Stress"] += 1

    if sdnn > 50: scores["Calm"] += 1
    elif 30 <= sdnn <= 50: scores["Mild Stress"] += 1
    elif sdnn < 30: scores["High Stress"] += 1

    if 60 <= hr <= 75: scores["Calm"] += 1
    elif 76 <= hr <= 90: scores["Mild Stress"] += 1
    elif hr > 90: scores["High Stress"] += 1

    if pnn50 > 20: scores["Calm"] += 1
    elif 5 <= pnn50 <= 20: scores["Mild Stress"] += 1
    elif pnn50 < 5: scores["High Stress"] += 1

    return max(scores, key=scores.get)

# === AI AGENT LOGIC ===
def generate_dynamic_message(team_state: str, style: str):
    prompt = f"""
    You are an AI assistant helping a team of 3 people collaborate on a complex puzzle. 
    Right now, the team is {team_state}. 
    Write a single, short sentence to display on their screen to help them. 
    The tone must be {style}. Be natural and human-like. Do not be robotic.
    """
    try:
        response = llm_client.models.generate_content(
            model="gemini-1.5-flash",
            contents=prompt
        )
        return response.text.strip()
    except Exception as e:
        print(f"LLM Error: {e}")
        return "Let's take a quick pause to sync up, team!" 

def calculate_synchrony_and_intervene():
    global last_intervention_time
    
    if len(rmssd_history[1]) < 3 or len(rmssd_history[2]) < 3 or len(rmssd_history[3]) < 3:
        return

    p1, p2, p3 = rmssd_history[1][-3:], rmssd_history[2][-3:], rmssd_history[3][-3:]

    try:
        sync_12 = 0 if math.isnan(np.corrcoef(p1, p2)[0, 1]) else np.corrcoef(p1, p2)[0, 1]
        sync_13 = 0 if math.isnan(np.corrcoef(p1, p3)[0, 1]) else np.corrcoef(p1, p3)[0, 1]
        sync_23 = 0 if math.isnan(np.corrcoef(p2, p3)[0, 1]) else np.corrcoef(p2, p3)[0, 1]

        group_sync = np.mean([sync_12, sync_13, sync_23])
        current_time = asyncio.get_event_loop().time()
        
        if current_time - last_intervention_time < 120:
            return

        message = None
        trigger = None

        if "High Stress" in current_stress_states.values():
            print("\n>> HYBRID AI: Individual High Stress Detected!")
            message = generate_dynamic_message("experiencing high cognitive load and stress", "calming, empathetic, and brief")
            trigger = "High Individual Stress"
            
        elif group_sync < 0.30:
            print("\n>> HYBRID AI: Low Team Synchrony Detected!")
            message = generate_dynamic_message("working independently and not communicating well", "encouraging, collaborative, and directive")
            trigger = "Low Team Synchrony"
            
        if message:
            print(f">> AI SAYS: '{message}'\n")
            last_intervention_time = current_time
            
            # Instantly push to the React Dashboard
            asyncio.run_coroutine_threadsafe(
                broadcast_to_dashboard({"type": "intervention", "trigger": trigger, "message": message}),
                asyncio.get_event_loop()
            )
            
    except Exception as e:
        pass

def process_hrv(participant_id: int, raw_window: np.ndarray):
    try:
        signals, info = nk.ppg_process(raw_window, sampling_rate=50)
        if len(info['PPG_Peaks']) > 3:
            hrv_time = nk.hrv_time(info['PPG_Peaks'], sampling_rate=50)
            
            rmssd = hrv_time['HRV_RMSSD'].values[0]
            sdnn = hrv_time['HRV_SDNN'].values[0]
            pnn50 = hrv_time['HRV_pNN50'].values[0]
            hr = np.mean(signals['PPG_Rate'])
            
            stress_state = classify_stress_clinically(rmssd, sdnn, hr, pnn50)
            
            rmssd_history[participant_id].append(rmssd)
            current_stress_states[participant_id] = stress_state
            
            time_now = datetime.now().strftime("%H:%M:%S")
            print(f"[{time_now}] P{participant_id} | Status: {stress_state} | RMSSD: {rmssd:.1f}ms")
            
            if participant_id == 3:
                calculate_synchrony_and_intervene()
                
    except Exception:
        pass 

@app.post("/sensor-data")
async def receive_data(data: SensorData, background_tasks: BackgroundTasks):
    pid = data.participant_id
    if pid not in [1, 2, 3]: raise HTTPException(status_code=400)
        
    participant_buffers[pid].extend(data.ppg_samples)
    
    if len(participant_buffers[pid]) == WINDOW_SIZE:
        current_time = asyncio.get_event_loop().time()
        if current_time - last_inference_time[pid] >= 30.0:
            last_inference_time[pid] = current_time
            raw_window = np.array(participant_buffers[pid])
            background_tasks.add_task(process_hrv, pid, raw_window)
            
    return {"status": "buffered"}

# === THIS IS THE PART YOU WERE MISSING ===
if __name__ == "__main__":
    uvicorn.run(app, host="127.0.0.1", port=8000)